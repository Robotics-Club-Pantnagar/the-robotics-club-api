# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional CA cert (base64) for managed Postgres providers
AIVEN_CA_B64=

# Clerk
CLERK_TEAM_SECRET_KEY=sk_test_replace_me
CLERK_USER_SECRET_KEY=sk_test_replace_me
CLERK_USER_WEBHOOK_SECRET=whsec_replace_me
CLERK_TEAM_WEBHOOK_SECRET=whsec_replace_me
# Optional fallback webhook secret
CLERK_WEBHOOK_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Valkey (shared instance for application cache + BullMQ queue)
VALKEY_URL=redis://username:password@host:6379
# Optional individual fields instead of URL:
# VALKEY_HOST=localhost
# VALKEY_PORT=6379
# VALKEY_USERNAME=
# VALKEY_PASSWORD=
# VALKEY_DB=0

# Optional BullMQ override (only if queue should use a different instance)
# BULLMQ_REDIS_URL=redis://username:password@host:6379
# Optional individual fields instead of URL:
# BULLMQ_REDIS_HOST=localhost
# BULLMQ_REDIS_PORT=6379
# BULLMQ_REDIS_USERNAME=
# BULLMQ_REDIS_PASSWORD=
# BULLMQ_REDIS_DB=0

# Redis (dedicated tag search / RediSearch instance)
REDIS_URL=redis://username:password@host:6379
# Optional individual fields instead of URL:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_DB=0

# App
PORT=3000
NODE_ENV=development
CLERK_MEMBER_REDIRECT_URL=
